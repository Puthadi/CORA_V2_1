{
  "name": "costcenter-error-agent",
  "version": "1.0.0",
  "description": "AI Agent for SAP Cost Center Error Resolution",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "cds-serve",
    "dev": "cds watch",
    "build": "cds build --production",
    "deploy:sqlite": "cds deploy --to sqlite",
    "test": "jest --testEnvironment node"
  },
  "dependencies": {
    "@sap/cds": "^8",
    "@sap/xssec": "^4",
    "@sap-cloud-sdk/http-client": "^3",
    "@sap-cloud-sdk/connectivity": "^3",
    "@sap-cloud-sdk/resilience": "^3",
    "axios": "^1.7",
    "express": "^4",
    "passport": "^0.7",
    "dotenv": "^16",
    "uuid": "^9"
  },
  "devDependencies": {
    "@sap/cds-dk": "^8",
    "jest": "^29",
    "sqlite3": "^5"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "hana-cloud",
        "[development]": {
          "kind": "sqlite",
          "credentials": {
            "database": ":memory:"
          }
        }
      },
      "XSUAA": {
        "kind": "xsuaa"
      },
      "connectivity": {
        "kind": "connectivity"
      },
      "destination": {
        "kind": "destination"
      }
    }
  }
}
