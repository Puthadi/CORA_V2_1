  "conversationTests": [

    {
      "testId": "TC-001",
      "name": "KS113 — Cost Center Blocked for Primary Postings",
      "errorLayer": "MASTER_DATA",
      "turns": [
        {
          "turn": 1,
          "role": "user",
          "message": "Analyze this SAP error: KS113 — \"Cost Center CC1000 is blocked for primary postings in period 05/2026\" on cost center CC1000 (1000).",
          "context": {
            "errorCode": "KS113",
            "errorText": "Cost Center CC1000 is blocked for primary postings in period 05/2026",
            "costCenter": "CC1000",
            "companyCode": "1000",
            "controllingArea": "A000",
            "fiscalYear": "2026",
            "fiscalPeriod": "005",
            "userId": "SARAH",
            "processContext": "Manual journal entry posting",
            "documentNumber": "1800001234"
          }
        },
        {
          "turn": 2,
          "role": "bot",
          "expectedIntent": "error_analysis",
          "acceptanceCriteria": {
            "rootCauseKeywords": ["posting block", "31-May-2026", "primary"],
            "minRecommendations": 2,
            "expectedRecommendations": [
              {
                "priority": "HIGH",
                "actionCode": "CREATE_WORKFLOW",
                "titleContains": "unlock"
              },
              {
                "priority": "MEDIUM",
                "actionCode": "LAUNCH_FIORI",
                "titleContains": "alternative"
              }
            ]
          }
        }
      ]
    },

